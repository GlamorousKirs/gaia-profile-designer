{
  "name": "gaia-profile-designer",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "generate-themeswatches": "tsx ./app/scripts/generate-themeswatches.ts",
    "generate:selectors": "tsx app/scripts/generate-selectors.ts",
    "predev": "npm run generate-themeswatches && npm run generate:selectors",
    "prebuild": "npm run generate-themeswatches && npm run generate:selectors",
    "prev": "npm run build && npm run start"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@react-router/node": "7.15.1",
    "@react-router/serve": "7.15.1",
    "@tanstack/react-virtual": "^3.14.3",
    "@uiw/codemirror-extensions-langs": "^4.25.10",
    "@uiw/codemirror-themes": "^4.25.10",
    "@uiw/react-codemirror": "^4.25.10",
    "autoprefixer": "^10.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "color-string": "^2.1.4",
    "color-thief-react": "^2.1.0",
    "colord": "^2.9.3",
    "driver.js": "^1.4.0",
    "idb-keyval": "^6.2.5",
    "isbot": "^5",
    "lucide-react": "^1.18.0",
    "motion": "^12.40.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.6",
    "react-colorful": "^5.7.0",
    "react-dom": "^19.2.6",
    "react-router": "7.15.1",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "toml": "^4.1.1",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@react-router/dev": "7.15.1",
    "@tailwindcss/vite": "^4",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "sharp": "^0.35.1",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^6",
    "vite": "^8",
    "vite-plugin-compression": "^0.5.1"
  }
}
